{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "user"] },
        "position": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "phone", "createdAt", "approved"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["ca-nhan", "doanh-nghiep"] },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "debt": { "type": "number" },
        "companyName": { "type": "string" },
        "department": { "type": "string" },
        "taxCode": { "type": "string" },
        "notes": { "type": "string" },
        "totalOrders": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "devices": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "type", "phone", "email", "address", "debt"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "products": { "type": "string" },
        "debt": { "type": "number" }
      },
      "required": ["id", "name", "phone", "email", "address", "products", "debt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "importPrice": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "supplier": { "type": "string" }
      },
      "required": ["id", "name", "category", "price", "stock", "minStock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parent": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" }
      },
      "required": ["id", "customerId", "customerName", "date", "time", "products", "total", "status", "paymentMethod", "paymentStatus"]
    },
    "ShopInfo": {
      "title": "ShopInfo",
      "description": "Shop information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "taxCode": { "type": "string" },
        "website": { "type": "string" },
        "bankAccount": { "type": "string" },
        "bankName": { "type": "string" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "App settings",
      "type": "object",
      "properties": {
        "currency": { "type": "string" },
        "dateFormat": { "type": "string" },
        "theme": { "type": "string" },
        "notifications": { "type": "boolean" },
        "autoBackup": { "type": "boolean" },
        "invoiceTemplate": { "type": "string" }
      }
    },
    "NotificationSettings": {
      "title": "Notification Settings",
      "description": "Settings for Zalo and SMS notifications",
      "type": "object",
      "properties": {
        "zaloAccessToken": { "type": "string" },
        "zaloOaId": { "type": "string" },
        "smsApiKey": { "type": "string" },
        "smsProvider": { "type": "string", "enum": ["esms", "twilio", "other"] },
        "autoSendWarranty": { "type": "boolean" },
        "daysBeforeExpiry": { "type": "number" },
        "messageTemplate": { "type": "string" }
      }
    },
    "WarrantyNotification": {
      "title": "Warranty Notification",
      "description": "Record of a sent warranty notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "orderId": { "type": "string" },
        "serviceTag": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "type": { "type": "string", "enum": ["zalo", "sms"] },
        "message": { "type": "string" }
      },
      "required": ["id", "customerId", "sentAt", "status", "type"]
    },
    "Store": {
      "title": "Store",
      "description": "Store metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["id", "name", "ownerUid", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Internal message between users or in groups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "receiverName": { "type": "string" },
        "groupId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["text", "task"] },
        "taskId": { "type": "string" }
      },
      "required": ["id", "senderId", "senderName", "content", "createdAt", "read"]
    },
    "Group": {
      "title": "Group",
      "description": "Group chat information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "memberIds", "createdBy", "createdAt"]
    },
    "InternalTask": {
      "title": "InternalTask",
      "description": "Task assigned to a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "messageId": { "type": "string" }
      },
      "required": ["id", "title", "assignedTo", "status", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Customer database"
    },
    "suppliers/{supplierId}": {
      "schema": { "$ref": "#/entities/Supplier" },
      "description": "Supplier database"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Product inventory"
    },
    "categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Sales orders"
    },
    "repairs/{repairId}": {
      "schema": { "type": "object" },
      "description": "Repair tickets"
    },
    "warrantyNotifications/{notificationId}": {
      "schema": { "$ref": "#/entities/WarrantyNotification" },
      "description": "Warranty notification logs"
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Internal messages between users or in groups"
    },
    "groups/{groupId}": {
      "schema": { "$ref": "#/entities/Group" },
      "description": "Group chat metadata"
    },
    "internalTasks/{taskId}": {
      "schema": { "$ref": "#/entities/InternalTask" },
      "description": "Internal tasks assigned via chat"
    },
    "config/shopInfo": {
      "schema": { "$ref": "#/entities/ShopInfo" },
      "description": "Shop general information"
    },
    "config/settings": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Application settings"
    },
    "config/notificationSettings": {
      "schema": { "$ref": "#/entities/NotificationSettings" },
      "description": "Notification API settings"
    }
  }
}
