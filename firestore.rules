rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is approved (Super admins or approved users)
    function isApproved() {
      return isAuthenticated() && (
        request.auth.uid == 'bUo9YdUJKmQih6Se7V7P2uzIYY82' ||
        request.auth.token.email == 'dieuhuu1995@gmail.com' ||
        request.auth.token.get('email', '') == 'dieuhuu1995@gmail.com' ||
        request.auth.token.email == 'huulaptop.info@gmail.com' ||
        request.auth.token.get('email', '') == 'huulaptop.info@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true)
      );
    }

    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'bUo9YdUJKmQih6Se7V7P2uzIYY82' ||
        request.auth.token.email == 'dieuhuu1995@gmail.com' ||
        request.auth.token.get('email', '') == 'dieuhuu1995@gmail.com' ||
        request.auth.token.email == 'huulaptop.info@gmail.com' ||
        request.auth.token.get('email', '') == 'huulaptop.info@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Specific rule for users to allow self-creation and admin access
    match /users/{userId} {
      allow read: if isApproved();
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // Specific rule for internal messages
    match /messages/{messageId} {
      allow read: if isApproved() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        (resource.data.groupId != null && 
         get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds.hasAny([request.auth.uid]))
      );
      allow create: if isApproved() && request.resource.data.senderId == request.auth.uid;
      allow update: if isApproved() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        (resource.data.groupId != null && 
         get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds.hasAny([request.auth.uid]))
      );
    }

    // Specific rule for groups
    match /groups/{groupId} {
      allow read: if isApproved() && resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isApproved() && resource.data.memberIds.hasAny([request.auth.uid]));
      allow delete: if isAdmin();
    }

    // Specific rule for internal tasks
    match /internalTasks/{taskId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Specific rule for customers to allow public warranty search by phone
    match /customers/{customerId} {
      // Allow list for public warranty search (limit 10)
      allow list: if request.query.limit <= 10;
      allow read, write: if isApproved();
    }

    // Specific rule for orders to allow public warranty check
    match /orders/{orderId} {
      // Allow list for public warranty check (limit 50)
      allow list: if request.query.limit <= 50;
      allow read, write: if isApproved();
    }

    // Default rule for other collections
    match /{allPaths=**} {
      allow read, write: if isApproved();
    }
  }
}
